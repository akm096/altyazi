[{"row":1,"start":"00:00:06.000","end":"00:00:11.000","text":"Bu çeviri Anizium için hazırlanmıştır.\nÇevirmen: Alogend","position":"normal"},{"row":2,"start":"00:00:19.150","end":"00:00:24.830","text":"<i>Duvarlar, bir yüzyıl boyunca\nbarış ve güvenlik sağladı.</i>","position":"normal"},{"row":3,"start":"00:00:27.960","end":"00:00:30.710","text":"<i>İnsanlar sonunda unutmuşlardı,</i>","position":"normal"},{"row":4,"start":"00:00:32.000","end":"00:00:35.380","text":"<i>hem boyun eğmenin korkusunu\nhem de kafese kapatılmanın utancını.</i>","position":"normal"},{"row":5,"start":"00:00:38.420","end":"00:00:39.680","text":"<i>Ama bir gün...</i>","position":"normal"},{"row":6,"start":"00:00:53.650","end":"00:00:57.070","text":"<i>Titanlar bir anda duvarı aştı</i>","position":"normal"},{"row":7,"start":"00:00:57.780","end":"00:01:00.570","text":"<i>ve insanlığı hayatta\nkalma savaşına sürükledi.</i>","position":"normal"},{"row":8,"start":"00:01:03.120","end":"00:01:09.790","text":"<i>Sayısız asker ve sivil kayıp arasında,</i>","position":"normal"},{"row":9,"start":"00:01:10.580","end":"00:01:15.710","text":"<i>titanların insanların\narasına sızdığı ortaya çıktı.</i>","position":"normal"},{"row":10,"start":"00:01:16.170","end":"00:01:18.425","text":"<i>Sonunda, insanlar bu kılık değiştirmiş</i>","position":"normal"},{"row":11,"start":"00:01:18.425","end":"00:01:22.300","text":"<i>titanlardan biri olan Annie\nLeonhart'ı yakalamayı başardı.</i>","position":"normal"},{"row":12,"start":"00:01:23.300","end":"00:01:27.760","text":"<i>Bu ilk duvarın düşmesinden\nbeş yıl sonra olmuştu.</i>","position":"normal"},{"row":13,"start":"00:01:37.150","end":"00:01:38.360","text":"<i>Ancak</i>","position":"normal"},{"row":14,"start":"00:01:40.400","end":"00:01:46.450","text":"<i>insanlığın bir sonraki\ntehditi hızla yaklaşmaktaydı.</i>","position":"normal"},{"row":15,"start":"00:02:00.510","end":"00:02:01.260","text":"Hey!","position":"normal"},{"row":16,"start":"00:02:01.260","end":"00:02:02.340","text":"Yukarıya baksanıza!","position":"normal"},{"row":17,"start":"00:02:08.810","end":"00:02:10.140","text":"Titan mı?","position":"normal"},{"row":18,"start":"00:02:10.140","end":"00:02:12.390","text":"Neden duvarın içinde?","position":"normal"},{"row":19,"start":"00:02:12.390","end":"00:02:13.600","text":"Çok saçma!","position":"normal"},{"row":20,"start":"00:02:16.770","end":"00:02:18.570","text":"Emirleriniz nedir, Ekip Lideri?","position":"normal"},{"row":21,"start":"00:02:18.570","end":"00:02:21.860","text":"Ne? Dur bir saniye!","position":"normal"},{"row":22,"start":"00:02:22.860","end":"00:02:26.450","text":"<i>Bu sadece bir tesadüf mü?</i>","position":"normal"},{"row":23,"start":"00:02:26.450","end":"00:02:29.740","text":"<i>Yoksa bu...</i>","position":"normal"},{"row":24,"start":"00:02:35.080","end":"00:02:36.750","text":"Rahip Nick?","position":"normal"},{"row":25,"start":"00:02:36.750","end":"00:02:38.040","text":"Ne olursa olsun,","position":"normal"},{"row":26,"start":"00:02:39.750","end":"00:02:43.300","text":"o titana zarar gelmesine\nasla izin vermemelisiniz!","position":"normal"},{"row":27,"start":"00:02:45.430","end":"00:02:46.590","text":"Ne?","position":"normal"},{"row":28,"start":"00:04:17.980","end":"00:04:22.980","text":"Canavar Titan","position":"normal"},{"row":29,"start":"00:04:24.820","end":"00:04:29.280","text":"Duvar Titan'ı için geçici\nbir çözüm sağladık.","position":"normal"},{"row":30,"start":"00:04:29.280","end":"00:04:31.990","text":"Hava karardıktan sonra\ndaha kalıcı çözümler bulacağız.","position":"normal"},{"row":31,"start":"00:04:32.450","end":"00:04:33.490","text":"Anladım.","position":"normal"},{"row":32,"start":"00:04:34.120","end":"00:04:37.000","text":"Bunu nasıl yorumlamalıyız, efendim?","position":"normal"},{"row":33,"start":"00:04:37.450","end":"00:04:40.500","text":"Duvarların içinde Titanlar\nolabileceğini hiç hayal etmemiştim.","position":"normal"},{"row":34,"start":"00:04:40.500","end":"00:04:42.750","text":"Kimse edemezdi.","position":"normal"},{"row":35,"start":"00:04:43.670","end":"00:04:47.300","text":"Sadece bilenler ve bilmeyenler vardı.","position":"normal"},{"row":36,"start":"00:04:50.300","end":"00:04:52.300","text":"Burada neler oluyor?","position":"normal"},{"row":37,"start":"00:04:52.300","end":"00:04:56.520","text":"Duvarların içinde titanla savaştık, ama\nbize nasıl geldiğini bile söylemiyorlar.","position":"normal"},{"row":38,"start":"00:04:57.520","end":"00:04:59.560","text":"Tabii ki söylemezler.","position":"normal"},{"row":39,"start":"00:04:59.560","end":"00:05:02.020","text":"Ama en kötüsü,","position":"normal"},{"row":40,"start":"00:05:03.020","end":"00:05:08.360","text":"bunca insanın ölümüne neden\nolan şeyi örtbas edecek olmaları.","position":"normal"},{"row":41,"start":"00:05:11.530","end":"00:05:12.530","text":"Şimdi,","position":"normal"},{"row":42,"start":"00:05:13.620","end":"00:05:16.240","text":"anlat bakalım.","position":"normal"},{"row":43,"start":"00:05:17.910","end":"00:05:20.750","text":"Bana bu titanın ne olduğunu söyle.","position":"normal"},{"row":44,"start":"00:05:21.710","end":"00:05:25.380","text":"Duvarın içinde ne işi var?","position":"normal"},{"row":45,"start":"00:05:27.340","end":"00:05:33.470","text":"Ve sizler neden onun\nvarlığını gizli tutuyordunuz?","position":"normal"},{"row":46,"start":"00:05:38.970","end":"00:05:41.020","text":"Bunun için zamanım yok!","position":"normal"},{"row":47,"start":"00:05:41.020","end":"00:05:43.850","text":"Kilisem yıkıldı,\ntakipçilerim kargaşa içinde!","position":"normal"},{"row":48,"start":"00:05:43.850","end":"00:05:45.520","text":"Ve bu senin suçun!","position":"normal"},{"row":49,"start":"00:05:45.520","end":"00:05:47.230","text":"Bunun telafisini yapacaksınız.","position":"normal"},{"row":50,"start":"00:05:47.900","end":"00:05:50.900","text":"Şimdi beni aşağı indirin!","position":"normal"},{"row":51,"start":"00:05:50.900","end":"00:05:52.110","text":"Elbette.","position":"normal"},{"row":52,"start":"00:05:53.780","end":"00:05:56.280","text":"Dosdoğru aşağıya inmek ister misin?","position":"normal"},{"row":53,"start":"00:05:58.540","end":"00:05:59.290","text":"Ekip Lideri!","position":"normal"},{"row":54,"start":"00:05:59.290","end":"00:06:00.330","text":"Yaklaşmayın.","position":"normal"},{"row":55,"start":"00:06:01.040","end":"00:06:03.080","text":"Bıktım artık!","position":"normal"},{"row":56,"start":"00:06:03.080","end":"00:06:08.300","text":"Biz Keşif Birliği’nin ne için\nkan döktüğünün farkında mısın?","position":"normal"},{"row":57,"start":"00:06:08.800","end":"00:06:12.920","text":"Titanlardan özgürlüğümüzü geri almak için!","position":"normal"},{"row":58,"start":"00:06:14.090","end":"00:06:17.800","text":"Bu dava uğruna hayatımı\nfeda etmeye hazırım!","position":"normal"},{"row":59,"start":"00:06:18.930","end":"00:06:21.730","text":"Bak, senden iyilik istemiyorum,","position":"normal"},{"row":60,"start":"00:06:21.730","end":"00:06:24.730","text":"sana emir veriyorum. Konuşmaya başla.","position":"normal"},{"row":61,"start":"00:06:24.730","end":"00:06:27.940","text":"Eğer konuşmazsan, başka birini bulurum.","position":"normal"},{"row":62,"start":"00:06:27.940","end":"00:06:32.820","text":"Zaten senin lanet olası hayatını almak,\nfedakârlıklarımızı karşılamaya yetmez!","position":"normal"},{"row":63,"start":"00:06:33.530","end":"00:06:36.200","text":"Bırak beni!","position":"normal"},{"row":64,"start":"00:06:36.200","end":"00:06:38.780","text":"Şimdi mi bırakayım?","position":"normal"},{"row":65,"start":"00:06:38.780","end":"00:06:40.200","text":"Evet!","position":"normal"},{"row":66,"start":"00:06:40.200","end":"00:06:42.330","text":"Pekâlâ, o zaman öl.","position":"normal"},{"row":67,"start":"00:06:42.330","end":"00:06:43.200","text":"Hange-san!","position":"normal"},{"row":68,"start":"00:06:43.200","end":"00:06:46.880","text":"Ölümümle gözlerin açılsın!","position":"normal"},{"row":69,"start":"00:06:46.880","end":"00:06:49.710","text":"Görevimizden vazgeçmeyeceğiz!","position":"normal"},{"row":70,"start":"00:06:51.170","end":"00:06:52.210","text":"Yani","position":"normal"},{"row":71,"start":"00:06:52.760","end":"00:06:57.970","text":"bırak gideyim!","position":"normal"},{"row":72,"start":"00:07:02.020","end":"00:07:05.060","text":"Tanrım...","position":"normal"},{"row":73,"start":"00:07:15.650","end":"00:07:17.602","text":"Şaka yapıyorum sadece, bunu yapamazdım.","position":"normal"},{"row":74,"start":"00:07:19.820","end":"00:07:23.080","text":"Söylesene, Rahip Nick...","position":"normal"},{"row":75,"start":"00:07:24.450","end":"00:07:28.080","text":"Tüm duvarlar titanlardan mı oluşuyor?","position":"normal"},{"row":76,"start":"00:07:30.210","end":"00:07:32.050","text":"Ekip Lideri...","position":"normal"},{"row":77,"start":"00:07:32.050","end":"00:07:36.050","text":"Vay, bu hissi unuttuğuma inanamıyorum.","position":"normal"},{"row":78,"start":"00:07:36.840","end":"00:07:42.470","text":"Duvarların dışına ilk çıktığımdan\nberi böyle hissetmemiştim.","position":"normal"},{"row":79,"start":"00:07:45.480","end":"00:07:47.310","text":"Oldukça korkutucu...","position":"normal"},{"row":80,"start":"00:07:54.780","end":"00:07:57.360","text":"Daha hızlı! Komutan\nErwin’e haber vermeliyim!","position":"normal"},{"row":81,"start":"00:07:57.360","end":"00:07:59.110","text":"Kaybedecek vaktim yok!","position":"normal"},{"row":82,"start":"00:07:59.110","end":"00:08:01.910","text":"Rose Duvarı'nın içinde titanlar var!","position":"normal"},{"row":83,"start":"00:08:14.880","end":"00:08:17.720","text":"12 Saat Önce","position":"normal"},{"row":84,"start":"00:08:18.840","end":"00:08:22.430","text":"Sheena Duvarı'nın Güneyi","position":"normal"},{"row":85,"start":"00:08:25.970","end":"00:08:30.100","text":"Köyüm buranın biraz\ngüneyinde, biliyor muydun?","position":"normal"},{"row":86,"start":"00:08:30.100","end":"00:08:32.690","text":"Benim köyüm de oldukça yakın.","position":"normal"},{"row":87,"start":"00:08:33.150","end":"00:08:37.190","text":"Başlarım böyle işe. Neden\nziyaret etmemize izin vermiyorlar?","position":"normal"},{"row":88,"start":"00:08:38.570","end":"00:08:40.860","text":"Belki bu gece gizlice kaçarım.","position":"normal"},{"row":89,"start":"00:08:40.860","end":"00:08:46.830","text":"Ailem, düzgün bir insan olana\nkadar eve dönmememi söyledi.","position":"normal"},{"row":90,"start":"00:08:46.830","end":"00:08:51.580","text":"Benimkiler asker olmak için\nfazla cılız olduğumu söylediler.","position":"normal"},{"row":91,"start":"00:08:51.580","end":"00:08:56.800","text":"Dalga geçenler şimdi utansın, bu işte çok\niyiyim ve sınıfın en iyileri arasındayım!","position":"normal"},{"row":92,"start":"00:08:56.800","end":"00:08:59.630","text":"Gidip ziyaret etmeliyim ki\nsözlerini onlara yedireyim.","position":"normal"},{"row":93,"start":"00:09:00.090","end":"00:09:04.010","text":"Connie, eğer gizlice kaçmakta\nciddiysen yardım ederim.","position":"normal"},{"row":94,"start":"00:09:04.010","end":"00:09:05.760","text":"Ne? Neden ki?","position":"normal"},{"row":95,"start":"00:09:06.470","end":"00:09:08.100","text":"Sence de bu garip değil mi?","position":"normal"},{"row":96,"start":"00:09:08.810","end":"00:09:10.980","text":"Sivil kıyafetlerimizle bekleme halindeyiz.","position":"normal"},{"row":97,"start":"00:09:10.980","end":"00:09:14.336","text":"Neden antrenman yapmamıza ya da\nüniforma giymemize izin vermiyorlar?","position":"normal"},{"row":98,"start":"00:09:15.770","end":"00:09:17.110","text":"Ve dahası,","position":"normal"},{"row":99,"start":"00:09:17.480","end":"00:09:19.440","text":"üstlerimiz tam teçhizatlı.","position":"normal"},{"row":100,"start":"00:09:19.940","end":"00:09:23.620","text":"Duvarların içindeyiz, cephede değil.","position":"normal"},{"row":101,"start":"00:09:23.620","end":"00:09:25.280","text":"Neyle savaşmamız gerekiyor?","position":"normal"},{"row":102,"start":"00:09:25.280","end":"00:09:29.790","text":"Şey, bu bölgede ayılar var.","position":"normal"},{"row":103,"start":"00:09:29.790","end":"00:09:31.750","text":"Evet. Ayılar olabilir.","position":"normal"},{"row":104,"start":"00:09:31.750","end":"00:09:34.080","text":"Ayılarla baş etmek\niçin birkaç silah yeter.","position":"normal"},{"row":105,"start":"00:09:45.140","end":"00:09:47.720","text":"Gümleme sesleri duyuyorum!\nAyak sesleri gibi!","position":"normal"},{"row":106,"start":"00:09:49.390","end":"00:09:51.520","text":"Ne ima ediyorsun, Sasha?","position":"normal"},{"row":107,"start":"00:09:51.520","end":"00:09:54.560","text":"Eğer burada titanlar\nolduğunu düşünüyorsan...","position":"normal"},{"row":108,"start":"00:09:55.020","end":"00:09:58.150","text":"Bu ancak Rose Duvarı'nın\ndelinmesiyle mümkün olur.","position":"normal"},{"row":109,"start":"00:10:01.240","end":"00:10:02.360","text":"Mike?","position":"normal"},{"row":110,"start":"00:10:03.070","end":"00:10:06.990","text":"Tomas! Üç kişi seç ve haber yolla!","position":"normal"},{"row":111,"start":"00:10:07.660","end":"00:10:09.490","text":"Tüm bölgeleri bilgilendirin!","position":"normal"},{"row":112,"start":"00:10:11.120","end":"00:10:15.790","text":"Büyük olasılıkla, 104. Eğitim\nBirliği'nden hiçbiri titan değil!","position":"normal"},{"row":113,"start":"00:10:17.340","end":"00:10:20.670","text":"Güneyden birden fazla titan yaklaşıyor!","position":"normal"},{"row":114,"start":"00:10:20.670","end":"00:10:23.590","text":"Rose Duvarı aşıldı!","position":"normal"},{"row":115,"start":"00:10:25.470","end":"00:10:28.470","text":"Doğruyu söylüyorum! Ayak\nsesleri duyduğuma eminim!","position":"normal"},{"row":116,"start":"00:10:30.270","end":"00:10:32.020","text":"Herkes burada mı?","position":"normal"},{"row":117,"start":"00:10:32.020","end":"00:10:33.020","text":"Nanaba?","position":"normal"},{"row":118,"start":"00:10:33.640","end":"00:10:36.600","text":"Güneyde, 500 metre uzakta\nbirden fazla titan tespit ettik.","position":"normal"},{"row":119,"start":"00:10:37.060","end":"00:10:38.980","text":"Bu tarafa geliyorlar.","position":"normal"},{"row":120,"start":"00:10:39.570","end":"00:10:41.530","text":"Teçhizatınızı almak için vaktimiz yok.","position":"normal"},{"row":121,"start":"00:10:41.990","end":"00:10:46.530","text":"Atlara binin ve yakındaki\ntüm insanları tahliye edin.","position":"normal"},{"row":122,"start":"00:10:46.990","end":"00:10:48.450","text":"Anlaşıldı mı?","position":"normal"},{"row":123,"start":"00:10:48.450","end":"00:10:50.660","text":"Güneyden mi?","position":"normal"},{"row":124,"start":"00:10:52.120","end":"00:10:55.120","text":"Bu, duvarın gerçekten\ndelindiği anlamına mı geliyor?","position":"normal"},{"row":125,"start":"00:10:56.305","end":"00:10:57.460","text":"Hadi!","position":"normal"},{"row":126,"start":"00:10:57.460","end":"00:11:00.040","text":"Üzgünüm, ama öğle yemeği biraz gecikecek!","position":"normal"},{"row":127,"start":"00:11:05.800","end":"00:11:06.510","text":"Mike.","position":"normal"},{"row":128,"start":"00:11:09.010","end":"00:11:12.390","text":"Önümüzde dokuz tane var.","position":"normal"},{"row":129,"start":"00:11:16.270","end":"00:11:18.940","text":"Rose Duvarı'nı aştılar.","position":"normal"},{"row":130,"start":"00:11:22.860","end":"00:11:27.780","text":"Titanların sırrını, hatta onların gerçekte\nne olduğunu hiçbir zaman öğrenemedik.","position":"normal"},{"row":131,"start":"00:11:29.030","end":"00:11:31.410","text":"Ve şimdi o gün geldi.","position":"normal"},{"row":132,"start":"00:11:32.490","end":"00:11:34.330","text":"İnsanlık","position":"normal"},{"row":133,"start":"00:11:35.290","end":"00:11:36.410","text":"kaybetti.","position":"normal"},{"row":134,"start":"00:11:38.830","end":"00:11:41.040","text":"Hayır. Henüz kaybetmedi.","position":"normal"},{"row":135,"start":"00:11:43.300","end":"00:11:48.300","text":"Savaşma azmimiz olduğu\nsürece yenilmiş sayılmayız.","position":"normal"},{"row":136,"start":"00:11:49.720","end":"00:11:53.640","text":"Yani savaşmaya devam ettiğimiz\nsürece kaybetmemiş oluruz.","position":"normal"},{"row":137,"start":"00:11:59.400","end":"00:12:02.400","text":"Titanlar üsse ulaştığında,","position":"normal"},{"row":138,"start":"00:12:02.400","end":"00:12:07.570","text":"acemilerden ve deneyimlilerden\noluşan dört takıma ayrılacağız","position":"normal"},{"row":139,"start":"00:12:07.563","end":"00:12:12.233","text":"ve her takım farklı bir yöne gidecek!","position":"normal"},{"row":140,"start":"00:12:08.408","end":"00:12:12.368","text":"Yarckeli Bölgesi, Stohess Bölgesi, Trost\nBölgesi, Ehrmich Bölgesi, Sheena Duvarı","position":"margin_top"},{"row":141,"start":"00:12:12.368","end":"00:12:15.200","text":"Kuzey Ekibi, Güney Ekibi,\nDoğu Ekibi, Batı Ekibi","position":"margin_top"},{"row":142,"start":"00:12:12.240","end":"00:12:16.500","text":"Titanlarla savaşmaktan kaçının\nve insanların tahliyesine odaklanın!","position":"normal"},{"row":143,"start":"00:12:16.500","end":"00:12:19.170","text":"Bu bölgeyi bilen var mı?","position":"normal"},{"row":144,"start":"00:12:19.170","end":"00:12:20.210","text":"Ben!","position":"normal"},{"row":145,"start":"00:12:20.623","end":"00:12:22.790","text":"Buranın kuzeyindeki\nbir kasabadan geliyorum!","position":"normal"},{"row":146,"start":"00:12:22.790","end":"00:12:25.710","text":"Bu bölgeyi avucumun içi gibi bilirim!","position":"normal"},{"row":147,"start":"00:12:25.710","end":"00:12:27.380","text":"Connie de öyle!","position":"normal"},{"row":148,"start":"00:12:29.220","end":"00:12:30.590","text":"Connie?","position":"normal"},{"row":149,"start":"00:12:30.590","end":"00:12:31.890","text":"Köyüm...","position":"normal"},{"row":150,"start":"00:12:32.680","end":"00:12:34.810","text":"Köyüm güneyde...","position":"normal"},{"row":151,"start":"00:12:34.810","end":"00:12:37.310","text":"Titanların arka tarafında.","position":"normal"},{"row":152,"start":"00:12:38.560","end":"00:12:42.690","text":"Yakındaki yerleşim yerlerine bir grubu\nyönlendirebilirim. Ama sonrasında...","position":"normal"},{"row":153,"start":"00:12:42.690","end":"00:12:44.690","text":"Lütfen köyüme gitmeme izin verin.","position":"normal"},{"row":154,"start":"00:12:47.030","end":"00:12:47.940","text":"Peki.","position":"normal"},{"row":155,"start":"00:12:47.940","end":"00:12:50.950","text":"Güney ekibine sen rehberlik edeceksin.","position":"normal"},{"row":156,"start":"00:12:50.950","end":"00:12:52.030","text":"Emredersiniz!","position":"normal"},{"row":157,"start":"00:12:52.030","end":"00:12:54.080","text":"Connie, ben de seninle geleceğim.","position":"normal"},{"row":158,"start":"00:12:54.080","end":"00:12:56.790","text":"Güneye gitmek en tehlikelisi.","position":"normal"},{"row":159,"start":"00:12:56.790","end":"00:12:58.370","text":"Titanlar orada.","position":"normal"},{"row":160,"start":"00:12:58.370","end":"00:13:02.710","text":"Ne olmuş yani? Oraya gizlice gitmene\nyardım edecektim zaten, unuttun mu?","position":"normal"},{"row":161,"start":"00:13:02.710","end":"00:13:05.130","text":"Sende geliyorsun, değil mi Bertolt?","position":"normal"},{"row":162,"start":"00:13:07.880","end":"00:13:10.430","text":"Elbette geleceğim.","position":"normal"},{"row":163,"start":"00:13:13.800","end":"00:13:15.430","text":"Fark ettiyseniz","position":"normal"},{"row":164,"start":"00:13:15.430","end":"00:13:18.680","text":"bugün, insanlık tarihinin\nyeni en karanlık günü oldu!","position":"normal"},{"row":165,"start":"00:13:18.680","end":"00:13:24.310","text":"Eğer insanlığın sınırlarını aşması\ngereken bir gün varsa, o gün bu gündür!","position":"normal"},{"row":166,"start":"00:13:24.310","end":"00:13:27.150","text":"Titanlar üsse ulaştı!","position":"normal"},{"row":167,"start":"00:13:27.366","end":"00:13:32.366","text":"Bu çeviri Anizium için hazırlanmıştır.\nÇevirmen: Alogend","position":"normal"},{"row":168,"start":"00:13:32.700","end":"00:13:34.410","text":"Dağılın!","position":"normal"},{"row":169,"start":"00:13:34.410","end":"00:13:36.240","text":"Olabildiğince hızlı sürün!","position":"normal"},{"row":170,"start":"00:13:48.550","end":"00:13:49.260","text":"Neden","position":"normal"},{"row":171,"start":"00:13:49.920","end":"00:13:51.720","text":"hepsi koşmaya başladı?","position":"normal"},{"row":172,"start":"00:13:51.720","end":"00:13:53.840","text":"Çok hızlılar! Bize yetişecekler!","position":"normal"},{"row":173,"start":"00:13:55.470","end":"00:13:56.930","text":"Gelgar!","position":"normal"},{"row":174,"start":"00:13:57.930","end":"00:14:00.520","text":"Güney ekibinin sorumluluğunu\nsana bırakıyorum!","position":"normal"},{"row":175,"start":"00:14:00.520","end":"00:14:01.730","text":"Mike-san!","position":"normal"},{"row":176,"start":"00:14:03.350","end":"00:14:05.350","text":"Emredersiniz.","position":"normal"},{"row":177,"start":"00:14:05.860","end":"00:14:07.984","text":"Titanları uzaklaştırmak\niçin yem mi olacak?","position":"normal"},{"row":178,"start":"00:14:07.984","end":"00:14:10.084","text":"Yalnız gitmek intihar olur!\nTakip edeceğim!","position":"normal"},{"row":179,"start":"00:14:10.084","end":"00:14:13.400","text":"Hayır! Başka kimseyi feda edemeyiz!","position":"normal"},{"row":180,"start":"00:14:13.400","end":"00:14:15.320","text":"Ona güvenin!","position":"normal"},{"row":181,"start":"00:14:15.320","end":"00:14:18.530","text":"Kaptan Levi’den sonra en yetenekli kişi o!","position":"normal"},{"row":182,"start":"00:14:18.530","end":"00:14:21.370","text":"Aramızda bunu\nyapabilecek tek kişi o!","position":"normal"},{"row":183,"start":"00:14:42.980","end":"00:14:43.980","text":"Duvarların içindeki Titanlar\nhâlâ gizemini koruyor.","position":"normal"},{"row":184,"start":"00:14:43.980","end":"00:14:45.647","text":"Duvarların, Dişi Titan’ın kristaline\nbenzeyen bir maddeden yapıldığı görülüyor.","position":"normal"},{"row":185,"start":"00:14:45.647","end":"00:14:46.827","text":"Duvar Kilisesi’nin rahipleri\nbu konuda daha fazlasını","position":"normal"},{"row":186,"start":"00:14:46.827","end":"00:14:47.980","text":"biliyor gibi, ama hiçbir\nbilgi vermeye yanaşmıyorlar.","position":"normal"},{"row":187,"start":"00:15:01.240","end":"00:15:02.540","text":"Tanrım, Eren.","position":"normal"},{"row":188,"start":"00:15:03.160","end":"00:15:06.120","text":"Yine mi kavga ettin?","position":"normal"},{"row":189,"start":"00:15:06.120","end":"00:15:10.550","text":"O aptallar başlattı!\nBenimle dalga geçiyorlardı!","position":"normal"},{"row":190,"start":"00:15:10.550","end":"00:15:15.050","text":"Ve Mikasa yine arkanı\ntoplamak zorunda kaldı, değil mi?","position":"normal"},{"row":191,"start":"00:15:16.090","end":"00:15:17.010","text":"Sağ ol.","position":"normal"},{"row":192,"start":"00:15:22.565","end":"00:15:26.810","text":"Eren, biri ne kadar zalim olursa olsun\nya da ondan ne kadar nefret edersen et,","position":"normal"},{"row":193,"start":"00:15:26.810","end":"00:15:29.150","text":"düşünmeden bir şey yapamazsın!","position":"normal"},{"row":194,"start":"00:15:30.900","end":"00:15:32.650","text":"Erkek değil misin?","position":"normal"},{"row":195,"start":"00:15:32.650","end":"00:15:35.780","text":"Buna katlanman ve Mikasa’yı koruman gerek.","position":"normal"},{"row":196,"start":"00:16:24.330","end":"00:16:25.620","text":"Bu...","position":"normal"},{"row":197,"start":"00:16:26.370","end":"00:16:27.580","text":"Düştü.","position":"normal"},{"row":198,"start":"00:16:28.870","end":"00:16:31.960","text":"Yorgun görünüyorsun. Biraz uyu.","position":"normal"},{"row":199,"start":"00:16:32.920","end":"00:16:35.050","text":"Üzgünüm. İyiyim.","position":"normal"},{"row":200,"start":"00:16:36.090","end":"00:16:38.420","text":"O şey daha iyi günler görmüştü.","position":"normal"},{"row":201,"start":"00:16:38.420","end":"00:16:39.380","text":"Evet.","position":"normal"},{"row":202,"start":"00:16:40.130","end":"00:16:43.300","text":"Malzemeler arasında yeni\nbir tane bulabilir miyim bakayım.","position":"normal"},{"row":203,"start":"00:16:50.100","end":"00:16:51.650","text":"Eren! Mikasa!","position":"normal"},{"row":204,"start":"00:16:52.270","end":"00:16:53.560","text":"Acil durum!","position":"normal"},{"row":205,"start":"00:16:54.070","end":"00:16:57.280","text":"Titanlar Rose Duvarı'nı deldi!","position":"normal"},{"row":206,"start":"00:17:04.200","end":"00:17:07.540","text":"Başlarım böyle işe, lanet\ntitanlar bize hiç nefes aldırmıyor.","position":"normal"},{"row":207,"start":"00:17:09.790","end":"00:17:10.960","text":"Gidebilir misin?","position":"normal"},{"row":208,"start":"00:17:11.830","end":"00:17:13.580","text":"Sanki başka seçeneğim var.","position":"normal"},{"row":209,"start":"00:17:14.540","end":"00:17:19.090","text":"104. Ekibe Takım Lideri\nMike’ın göz kulak olması iyi oldu.","position":"normal"},{"row":210,"start":"00:17:19.090","end":"00:17:21.220","text":"Durumu iyi kontrol eder.","position":"normal"},{"row":211,"start":"00:17:21.970","end":"00:17:23.590","text":"Evet.","position":"normal"},{"row":212,"start":"00:17:24.510","end":"00:17:26.220","text":"Umarım öyle olur.","position":"normal"},{"row":213,"start":"00:17:43.070","end":"00:17:45.120","text":"<i>Dört tane kaldı.</i>","position":"normal"},{"row":214,"start":"00:17:51.160","end":"00:17:54.040","text":"<i>Hayır, geri dönmem lazım.</i>","position":"normal"},{"row":215,"start":"00:17:54.040","end":"00:17:56.170","text":"<i>Yeterince zaman kazandırdım.</i>","position":"normal"},{"row":216,"start":"00:18:05.470","end":"00:18:06.390","text":"<i>Ama</i>","position":"normal"},{"row":217,"start":"00:18:07.140","end":"00:18:09.100","text":"<i>şu anormal beni tedirgin ediyor.</i>","position":"normal"},{"row":218,"start":"00:18:10.430","end":"00:18:12.560","text":"<i>Onda bir gariplik var.</i>","position":"normal"},{"row":219,"start":"00:18:12.560","end":"00:18:14.980","text":"<i>17 metreden uzun olmalı.</i>","position":"normal"},{"row":220,"start":"00:18:15.730","end":"00:18:17.480","text":"<i>Çok büyük...</i>","position":"normal"},{"row":221,"start":"00:18:17.480","end":"00:18:21.740","text":"<i>Daha önce tüylerle kaplı\nbir titan hiç görmemiştim.</i>","position":"normal"},{"row":222,"start":"00:18:22.530","end":"00:18:26.950","text":"<i>Dahası, peşime düşmek\nyerine sadece etrafta dolanıyor.</i>","position":"normal"},{"row":223,"start":"00:18:26.950","end":"00:18:29.540","text":"<i>Kesinlikle bir anormal, ama...</i>","position":"normal"},{"row":224,"start":"00:18:32.040","end":"00:18:34.500","text":"<i>Harika! Geri dönüyor!</i>","position":"normal"},{"row":225,"start":"00:18:34.500","end":"00:18:37.250","text":"<i>Artık geceye kadar\ndayanmama gerek kalmayacak.</i>","position":"normal"},{"row":226,"start":"00:18:45.010","end":"00:18:47.470","text":"Atı mı hedefliyordu?","position":"normal"},{"row":227,"start":"00:18:48.300","end":"00:18:49.560","text":"Bu imkansız!","position":"normal"},{"row":228,"start":"00:19:10.990","end":"00:19:11.660","text":"Bekle.","position":"normal"},{"row":229,"start":"00:19:33.060","end":"00:19:38.060","text":"Beni duymadın mı?\nAz önce beklemeni söyledim.","position":"normal"},{"row":230,"start":"00:19:58.080","end":"00:20:01.000","text":"Kullandığın o silahın adı ne?","position":"normal"},{"row":231,"start":"00:20:06.300","end":"00:20:09.390","text":"Belinde, uçmanı sağlayan o şey.","position":"normal"},{"row":232,"start":"00:20:21.560","end":"00:20:24.820","text":"Aynı dili konuştuğumuza emindim...","position":"normal"},{"row":233,"start":"00:20:24.820","end":"00:20:27.900","text":"Belki de korkudan konuşamıyorsundur?","position":"normal"},{"row":234,"start":"00:20:28.650","end":"00:20:32.240","text":"Kılıç da kullandığını görüyorum.","position":"normal"},{"row":235,"start":"00:20:32.240","end":"00:20:36.500","text":"Belli ki ense kısmında\nolduğumuzu keşfetmişsiniz.","position":"normal"},{"row":236,"start":"00:20:36.500","end":"00:20:40.670","text":"Neyse, onu alayım bari.","position":"normal"},{"row":237,"start":"00:21:05.360","end":"00:21:10.450","text":"Savaşma azmimiz olduğu\nsürece yenilmiş sayılmayız.","position":"normal"},{"row":238,"start":"00:21:15.370","end":"00:21:17.910","text":"<i>Yani savaşmaya devam ettiğimiz sürece,</i>","position":"normal"},{"row":239,"start":"00:21:19.410","end":"00:21:21.830","text":"<i>kaybetmemiş oluruz!</i>","position":"normal"},{"row":240,"start":"00:21:28.920","end":"00:21:31.760","text":"Artık hareket edebilirsiniz.","position":"normal"},{"row":241,"start":"00:21:36.560","end":"00:21:41.190","text":"Hayır! Hayır!","position":"normal"},{"row":242,"start":"00:21:41.190","end":"00:21:45.480","text":"Dur! Yapma! Hayır! Hayır!","position":"normal"},{"row":243,"start":"00:21:48.820","end":"00:21:51.990","text":"Anladım. Demek konuşabiliyormuşsun.","position":"normal"},{"row":244,"start":"00:21:56.080","end":"00:22:00.580","text":"Ne kadar dahice bir alet icat etmişler.","position":"normal"},{"row":245,"start":"00:22:03.000","end":"00:22:06.630","text":"Hayır! Hayır!","position":"normal"},{"row":246,"start":"00:22:06.630","end":"00:22:11.130","text":"Dur! Hayır!","position":"normal"},{"row":247,"start":"00:23:47.440","end":"00:23:50.980","text":"Titanlar aniden Rose\nDuvarı'nın içinde belirdi.","position":"normal"},{"row":248,"start":"00:23:51.940","end":"00:23:53.860","text":"104. Eğitim Birliği’nden askerler,","position":"normal"},{"row":249,"start":"00:23:54.230","end":"00:23:57.780","text":"haberi yaymak için dağıldı.","position":"normal"},{"row":250,"start":"00:23:58.240","end":"00:24:02.280","text":"Bu sırada, Eren ve diğerleri\ndestek sağlamak için harekete geçti.","position":"normal"},{"row":251,"start":"00:24:03.740","end":"00:24:06.710","text":"Ve köyüne döndükten sonra Sasha,","position":"normal"},{"row":252,"start":"00:24:06.710","end":"00:24:10.040","text":"geçmişiyle yüzleşmek zorunda kalacak.","position":"normal"},{"row":253,"start":"00:24:11.500","end":"00:24:15.210","text":"Sonraki bölüm: “Ben geldim.”","position":"normal"},{"row":254,"start":"00:24:11.500","end":"00:24:16.010","text":"Ben geldim","position":"normal"}]